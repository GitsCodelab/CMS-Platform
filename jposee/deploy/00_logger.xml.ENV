<?xml version="1.0" encoding="UTF-8"?>
<logger name="org.jpos" class="org.jpos.util.SimpleLogListener">
    <property name="logfile" value="log/q2ee.log"/>
    <property name="rotate" value="true"/>
    <property name="maxsize" value="10485760"/> <!-- 10 MB -->
    <property name="backups" value="10"/>
    <property name="append" value="true"/>
</logger>
