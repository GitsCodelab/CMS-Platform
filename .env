# DUKPT Configuration
# Base Derivation Key (16 bytes) - used for DUKPT session key derivation
JPOS_BDK_HEX=0123456789ABCDEFFEDCBA9876543210

# MAC Key (24 bytes / 192-bit) - used for message authentication codes
JPOS_MAC_KEY_HEX=2D4F5A7B9E1C3F8A5D2E9B6C4A1F7E3B9D2C5F8A1E7B4A9

# Gateway Configuration
JPOS_PORT=8583
JPOS_SOCKET_TIMEOUT_MS=5000
JPOS_MAX_MESSAGE_LENGTH=4096
JPOS_MAX_CLIENTS=32
JPOS_REPLAY_WINDOW_SECONDS=300
JPOS_REQUIRE_MAC=true
JPOS_REQUIRE_TLS=false
LOG_LEVEL=INFO
