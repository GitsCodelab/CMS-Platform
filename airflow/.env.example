### Example environment variables for Airflow (do NOT commit real credentials)
# Copy this to `.env` and fill in secret values.

# Oracle connection details
ORACLE_USER=recon_user
ORACLE_PASS=recon_pass
ORACLE_HOST=recon-oracle
ORACLE_PORT=1521
ORACLE_SERVICE=xepdb1

# Constructed AIRFLOW connection URI (example):
# AIRFLOW_CONN_ORACLE_MAIN=oracle+oracledb://${ORACLE_USER}:${ORACLE_PASS}@${ORACLE_HOST}:${ORACLE_PORT}/?service_name=${ORACLE_SERVICE}

# Example: uncomment and set in your `.env` (do not commit):
# AIRFLOW_CONN_ORACLE_MAIN=oracle+oracledb://recon_user:recon_pass@recon-oracle:1521/?service_name=xepdb1
