# Airflow Version 3 Configuration
# Official Airflow 3.x Settings

# Core Settings
AIRFLOW_VERSION=latest
AIRFLOW_UID=50000
AIRFLOW_GID=50000

# Database Configuration
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Airflow Core Settings
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__LOAD_DEFAULT_CONNECTIONS=false
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__ENABLE_XCOM_PICKLING=false
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16

# Database Connection Strings
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# Celery Configuration
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres:5432/airflow

# Logging
AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs
AIRFLOW__LOGGING__LOG_SERVER_HOST=cms-airflow
AIRFLOW__LOGGING__LOG_SERVER_PORT=8793

# API Settings
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.session
AIRFLOW__INTERNAL_API__URL=http://airflow-api-server:8080
AIRFLOW__CORE__DEFAULT_TIMEZONE=UTC

# Scheduler Settings
AIRFLOW__SCHEDULER__SCHEDULER_HEARTBEAT_SEC=5

# DAG Processor Settings (Airflow 3.0+)
AIRFLOW__DAG_PROCESSOR__REFRESH_INTERVAL=300

# Worker Settings
AIRFLOW__CELERY__WORKER_CONCURRENCY=8

# Security
AIRFLOW__WEBSERVER__RBAC=true

# SimpleAuthManager Configuration (Airflow 3.x)
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS=airflow:admin,viewer:viewer
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_PASSWORDS_FILE=/opt/airflow/simple_auth_manager_passwords.json
 
# Fernet key for encrypting/decrypting connection passwords
AIRFLOW__CORE__FERNET_KEY=cuAwqAilSXSdBLPqnZ-qCbEyFxqrrlTf1nNQ3qu4A6I=

# Placeholder .env file for Airflow
# Add necessary environment variables here
