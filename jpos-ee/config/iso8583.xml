<?xml version="1.0" encoding="UTF-8"?>
<isopackager>
    <!--
        ISO 8583 Packager Configuration
        Standard message format for financial transactions
    -->

    <!-- Message Type -->
    <isofield id="0" length="4" type="NUMERIC" name="Message Type Indicator"/>

    <!-- Bitmap Field (Primary and Secondary) -->
    <isofield id="1" length="8" type="BITMAP" name="Bit Map"/>

    <!-- Financial Data -->
    <isofield id="2" length="19" type="LLNUM" name="Primary Account Number (PAN)"/>
    <isofield id="3" length="6" type="NUMERIC" name="Processing Code"/>
    <isofield id="4" length="12" type="NUMERIC" name="Amount (Transaction)"/>
    <isofield id="5" length="12" type="NUMERIC" name="Amount (Reconciliation)"/>
    <isofield id="6" length="12" type="NUMERIC" name="Amount (Cardholder Billing)"/>
    <isofield id="7" length="10" type="NUMERIC" name="Transmission Date and Time"/>
    <isofield id="8" length="8" type="NUMERIC" name="Amount (Cardholder Billing Fee)"/>
    <isofield id="9" length="8" type="NUMERIC" name="Conversion Rate (Reconciliation)"/>
    <isofield id="10" length="8" type="NUMERIC" name="Conversion Rate (Cardholder Billing)"/>
    <isofield id="11" length="6" type="NUMERIC" name="Systems Trace Audit Number (STAN)"/>
    <isofield id="12" length="6" type="NUMERIC" name="Time, Local Transaction"/>
    <isofield id="13" length="4" type="NUMERIC" name="Date, Local Transaction"/>
    <isofield id="14" length="4" type="NUMERIC" name="Date, Expiration"/>
    <isofield id="15" length="4" type="NUMERIC" name="Date, Settlement"/>

    <!-- Merchant and Cardholder Data -->
    <isofield id="19" length="3" type="NUMERIC" name="Country Code, Acquiring Institution"/>
    <isofield id="20" length="3" type="NUMERIC" name="Country Code, PAN Issuing Institution"/>
    <isofield id="21" length="3" type="NUMERIC" name="Forward Institution Country Code"/>
    <isofield id="22" length="3" type="NUMERIC" name="Point of Service Entry Mode"/>
    <isofield id="23" length="3" type="NUMERIC" name="Card Sequence Number"/>
    <isofield id="24" length="3" type="NUMERIC" name="Function Code"/>
    <isofield id="25" length="2" type="NUMERIC" name="Message Reason Code"/>
    <isofield id="26" length="2" type="NUMERIC" name="Card Acceptor Business Code"/>
    <isofield id="27" length="1" type="NUMERIC" name="Response Code"/>
    <isofield id="28" length="8" type="NUMERIC" name="Amount, Reconciliation"/>

    <!-- Reference Numbers -->
    <isofield id="37" length="12" type="ALPHA" name="Retrieval Reference Number"/>
    <isofield id="38" length="6" type="ALPHA" name="Authorization Identification Response"/>
    <isofield id="39" length="2" type="ALPHA" name="Response Code"/>
    <isofield id="41" length="8" type="ALPHA" name="Card Acceptor Terminal Identification"/>
    <isofield id="42" length="15" type="ALPHA" name="Card Acceptor Identification Code"/>
    <isofield id="43" length="40" type="ALPHA" name="Card Acceptor Name/Location"/>

    <!-- Message Fields -->
    <isofield id="49" length="3" type="NUMERIC" name="Currency Code, Transaction"/>
    <isofield id="50" length="3" type="NUMERIC" name="Currency Code, Settlement"/>
    <isofield id="51" length="3" type="NUMERIC" name="Currency Code, Cardholder Billing"/>
    <isofield id="52" length="8" type="BINARY" name="Personal Identification Number (PIN) Data"/>
    <isofield id="53" length="16" type="LLBINARY" name="Security Related Control Information"/>
    <isofield id="54" length="120" type="LLLCHAR" name="Amounts, Additional"/>
    <isofield id="55" length="255" type="LLBINARY" name="Integrated Circuit Card (ICC) System Related Data"/>
    <isofield id="56" length="255" type="LLBINARY" name="Reserved ISO"/>
    <isofield id="57" length="255" type="LLLCHAR" name="Reserved National"/>
    <isofield id="58" length="255" type="LLLCHAR" name="Reserved National"/>
    <isofield id="59" length="255" type="LLLCHAR" name="Reserved National"/>
    <isofield id="60" length="255" type="LLLCHAR" name="Reserved Private"/>
    <isofield id="61" length="255" type="LLLCHAR" name="Reserved Private"/>
    <isofield id="62" length="255" type="LLLCHAR" name="Reserved Private"/>
    <isofield id="63" length="255" type="LLLCHAR" name="Reserved Private"/>
    <isofield id="64" length="8" type="BINARY" name="Message Authentication Code (MAC)"/>
    <isofield id="65" length="8" type="BINARY" name="Bitmap, Tertiary"/>
    <isofield id="100" length="11" type="LLCHAR" name="Receiving Institution Identification Code"/>
    <isofield id="101" length="34" type="LLCHAR" name="File Name"/>
    <isofield id="102" length="28" type="LLCHAR" name="Account Identification 1"/>
    <isofield id="103" length="28" type="LLCHAR" name="Account Identification 2"/>
    <isofield id="104" length="100" type="LLLCHAR" name="Transaction Description"/>
    <isofield id="105" length="255" type="LLLCHAR" name="Reserved for ISO Use"/>
    <isofield id="106" length="255" type="LLLCHAR" name="Reserved for ISO Use"/>
    <isofield id="107" length="255" type="LLLCHAR" name="Reserved for ISO Use"/>
    <isofield id="108" length="255" type="LLLCHAR" name="Reserved for ISO Use"/>
    <isofield id="109" length="255" type="LLLCHAR" name="Reserved for ISO Use"/>
    <isofield id="110" length="255" type="LLLCHAR" name="Reserved for ISO Use"/>
    <isofield id="111" length="255" type="LLLCHAR" name="Reserved for ISO Use"/>
    <isofield id="112" length="255" type="LLLCHAR" name="Reserved for National Use"/>
    <isofield id="113" length="255" type="LLLCHAR" name="Reserved for National Use"/>
    <isofield id="114" length="255" type="LLLCHAR" name="Reserved for National Use"/>
    <isofield id="115" length="255" type="LLLCHAR" name="Reserved for National Use"/>
    <isofield id="116" length="255" type="LLLCHAR" name="Reserved for National Use"/>
    <isofield id="117" length="255" type="LLLCHAR" name="Reserved for National Use"/>
    <isofield id="118" length="255" type="LLLCHAR" name="Reserved for National Use"/>
    <isofield id="119" length="255" type="LLLCHAR" name="Reserved for National Use"/>
    <isofield id="120" length="255" type="LLLCHAR" name="Reserved for Private Use"/>
    <isofield id="121" length="255" type="LLLCHAR" name="Reserved for Private Use"/>
    <isofield id="122" length="255" type="LLLCHAR" name="Reserved for Private Use"/>
    <isofield id="123" length="255" type="LLLCHAR" name="Reserved for Private Use"/>
    <isofield id="124" length="255" type="LLLCHAR" name="Reserved for Private Use"/>
    <isofield id="125" length="255" type="LLLCHAR" name="Reserved for Private Use"/>
    <isofield id="126" length="255" type="LLLCHAR" name="Reserved for Private Use"/>
    <isofield id="127" length="255" type="LLLCHAR" name="Reserved for Private Use"/>
    <isofield id="128" length="8" type="BINARY" name="Message Authentication Code (MAC)"/>

</isopackager>
