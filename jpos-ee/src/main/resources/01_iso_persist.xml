<?xml version="1.0" encoding="UTF-8"?>
<!--
  jPOS TransactionManager Configuration
  
  Purpose: Define the participant chain for ISO 8583 transaction processing
  Execution order:
    1. PersistRequest (FIRST) - Saves raw request to database immediately
    2. Business processing participants (middle layers)
    3. UpdateResponse (LAST) - Updates transaction with response data
  
  PCI-DSS Compliance:
    - Requirement 10.1: All transactions logged with timestamp
    - Requirement 10.2: User/IP/session captured
    - Requirement 10.3: Immutable audit trail maintained
  
  Configuration: TransactionManager (org.jpos.transaction.TransactionManager)
  - AbortTimeout: 120 seconds (2 min) - time before transaction auto-aborts
  - IdleTimeout: 300 seconds (5 min) - maximum transaction lifetime
  - MaxSessions: 1000 - maximum concurrent transactions
  
  Author: jPOS-EE Persistence Layer
  Version: 1.0
  Date: April 21, 2026
-->
<txnmgr>
  <!-- ============================================================ -->
  <!-- TRANSACTION MANAGER - Core orchestrator -->
  <!-- ============================================================ -->
  <transaction-manager 
      class="org.jpos.transaction.TransactionManager"
      name="TransactionManager"
      logger="Q2"
      realm="jposee-persistence">
    
    <!-- Participant 1: PERSIST REQUEST (First - immediate storage) -->
    <!-- 
      Saves incoming ISO 8583 transaction to database before any processing
      Status: RECEIVED
      Purpose: Ensure 100% transaction capture, immutable audit trail
      
      Failure: If save fails, transaction is aborted (transaction rolled back)
      Success: ISO_TXN_ID returned in context for downstream use
    -->
    <participant 
        class="org.cms.jposee.participant.PersistRequest"
        name="PersistRequest"
        logger="Q2"
        prepare="300s"
        commit="500ms"
        abort="500ms">
      <!-- Configuration for database repository injection -->
      <property name="repository-class" value="org.cms.jposee.repository.impl.IsoTransactionRepositoryImpl"/>
    </participant>
    
    <!-- Participant 2: UPDATE RESPONSE (Last - response handling) -->
    <!-- 
      Updates transaction with response data after processing
      Status: PROCESSED / DECLINED / FAILED
      Purpose: Complete transaction record with processor response
      
      Inputs: ISO_TXN_ID (from PersistRequest), ISO_RESPONSE in context
      Outputs: Transaction updated, audit trail entry created
    -->
    <participant 
        class="org.cms.jposee.participant.UpdateResponse"
        name="UpdateResponse"
        logger="Q2"
        prepare="300s"
        commit="500ms"
        abort="500ms">
      <!-- Configuration for repository injection -->
      <property name="txn-repository-class" value="org.cms.jposee.repository.impl.IsoTransactionRepositoryImpl"/>
      <property name="audit-repository-class" value="org.cms.jposee.repository.impl.IsoTransactionAuditRepositoryImpl"/>
    </participant>
    
    <!-- ============================================================ -->
    <!-- TRANSACTION TIMEOUTS & POLICIES -->
    <!-- ============================================================ -->
    
    <!-- AbortTimeout: Time before transaction auto-aborts if participant doesn't respond -->
    <!-- Set to 120 seconds (2 minutes) - gives participants reasonable time to complete -->
    <property name="abort-timeout" value="120s"/>
    
    <!-- IdleTimeout: Maximum lifetime for any transaction -->
    <!-- Set to 300 seconds (5 minutes) - upper bound for transaction processing -->
    <property name="idle-timeout" value="300s"/>
    
    <!-- MaxSessions: Maximum number of concurrent transactions in flight -->
    <!-- Set to 1000 - handles typical ISO transaction volumes -->
    <property name="max-sessions" value="1000"/>
    
    <!-- ============================================================ -->
    <!-- RETRY POLICY -->
    <!-- ============================================================ -->
    
    <!-- MaxRetries: How many times a failed transaction is retried -->
    <!-- Set to 3 - typical for transient failures -->
    <property name="max-retries" value="3"/>
    
    <!-- RetryDelay: Time to wait before retrying failed transaction -->
    <!-- Set to 1000ms (1 second) - standard retry interval -->
    <property name="retry-delay" value="1000"/>
    
    <!-- ============================================================ -->
    <!-- PERSISTENCE STORE -->
    <!-- ============================================================ -->
    
    <!-- Store transactions to queue for recovery if node crashes -->
    <!-- Uses file-based queue: target/tx.log -->
    <persistence 
        class="org.jpos.transaction.TransactionStore"
        logger="Q2"
        name="TransactionStore">
      <property name="path" value="target/tx.log"/>
    </persistence>
    
  </transaction-manager>

  <!-- ============================================================ -->
  <!-- TRANSACTION MONITOR (Optional - for diagnostics) -->
  <!-- ============================================================ -->
  
  <!-- Monitor transaction health and log statistics -->
  <transaction-monitor 
      class="org.jpos.transaction.TransactionMonitor"
      name="TransactionMonitor"
      logger="Q2">
    <!-- Check transaction status every 30 seconds -->
    <property name="check-interval" value="30s"/>
    <!-- Log transaction statistics -->
    <property name="log-statistics" value="true"/>
  </transaction-monitor>

</txnmgr>
