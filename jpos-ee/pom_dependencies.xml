<?xml version="1.0" encoding="UTF-8"?>
<!-- 
    Maven POM Dependencies for jPOS-EE ISO 8583 Persistence Module
    Date: April 21, 2026
    Purpose: Add all required dependencies for JPA/Hibernate + PostgreSQL
    
    Location: Add these to your jpos-ee/pom.xml in the <dependencies> section
    
    NOTE: Replace/merge with existing dependencies. Don't duplicate if already present.
-->

<!-- ====================================================================
     ADD THESE DEPENDENCIES TO YOUR POM.XML <dependencies> SECTION
     ==================================================================== -->

<!-- ====================================================================
     JAKARTA PERSISTENCE (JPA) - Java Persistence API
     Required for @Entity, @Table, @Column annotations
     ==================================================================== -->

<!-- JPA API -->
<dependency>
    <groupId>javax.persistence</groupId>
    <artifactId>javax.persistence-api</artifactId>
    <version>2.2</version>
</dependency>

<!-- ====================================================================
     HIBERNATE - ORM Framework (JPA Implementation)
     Implements JPA specification and handles database operations
     ==================================================================== -->

<!-- Hibernate Core -->
<dependency>
    <groupId>org.hibernate</groupId>
    <artifactId>hibernate-core</artifactId>
    <version>5.6.15.Final</version>
</dependency>

<!-- Hibernate Entity Manager (JPA provider) -->
<dependency>
    <groupId>org.hibernate</groupId>
    <artifactId>hibernate-entitymanager</artifactId>
    <version>5.6.15.Final</version>
</dependency>

<!-- Hibernate Tools (optional, but useful for schema validation) -->
<dependency>
    <groupId>org.hibernate</groupId>
    <artifactId>hibernate-tools</artifactId>
    <version>5.6.15.Final</version>
    <scope>test</scope>
</dependency>

<!-- ====================================================================
     POSTGRESQL DATABASE DRIVER
     JDBC driver to connect to PostgreSQL
     ==================================================================== -->

<dependency>
    <groupId>org.postgresql</groupId>
    <artifactId>postgresql</artifactId>
    <version>42.7.1</version>
</dependency>

<!-- ====================================================================
     CONNECTION POOL - HikariCP (for better performance)
     Alternative to C3P0, more modern and efficient
     ==================================================================== -->

<dependency>
    <groupId>com.zaxxer</groupId>
    <artifactId>HikariCP</artifactId>
    <version>5.0.1</version>
</dependency>

<!-- C3P0 Connection Pool (if you prefer it over HikariCP) -->
<!-- <dependency>
    <groupId>org.hibernate</groupId>
    <artifactId>hibernate-c3p0</artifactId>
    <version>5.6.15.Final</version>
</dependency> -->

<!-- ====================================================================
     LOGGING - SLF4J + Logback
     For logging database operations, SQL statements, etc.
     ==================================================================== -->

<!-- SLF4J API -->
<dependency>
    <groupId>org.slf4j</groupId>
    <artifactId>slf4j-api</artifactId>
    <version>2.0.5</version>
</dependency>

<!-- Logback Implementation -->
<dependency>
    <groupId>ch.qos.logback</groupId>
    <artifactId>logback-classic</artifactId>
    <version>1.4.5</version>
</dependency>

<!-- Bridge to redirect commons-logging to SLF4J -->
<dependency>
    <groupId>org.slf4j</groupId>
    <artifactId>jcl-over-slf4j</artifactId>
    <version>2.0.5</version>
</dependency>

<!-- ====================================================================
     VALIDATION - JSR 380 (Bean Validation)
     Optional but recommended for data validation
     ==================================================================== -->

<dependency>
    <groupId>javax.validation</groupId>
    <artifactId>validation-api</artifactId>
    <version>2.0.1.Final</version>
</dependency>

<dependency>
    <groupId>org.hibernate.validator</groupId>
    <artifactId>hibernate-validator</artifactId>
    <version>6.2.5.Final</version>
</dependency>

<!-- ====================================================================
     JPOS CORE - (You likely already have this)
     Required for ISOMsg, ISOPackager, etc.
     ==================================================================== -->

<!-- jPOS Core -->
<dependency>
    <groupId>org.jpos</groupId>
    <artifactId>jpos</artifactId>
    <version>2.1.9</version>
</dependency>

<!-- jPOS EE (if using jPOS Enterprise Edition modules) -->
<!-- <dependency>
    <groupId>org.jpos</groupId>
    <artifactId>jposee-txnmgr</artifactId>
    <version>2.2.4</version>
</dependency> -->

<!-- ====================================================================
     TESTING DEPENDENCIES
     ==================================================================== -->

<!-- JUnit 4 (or JUnit 5 if you prefer) -->
<dependency>
    <groupId>junit</groupId>
    <artifactId>junit</artifactId>
    <version>4.13.2</version>
    <scope>test</scope>
</dependency>

<!-- Mockito for mocking -->
<dependency>
    <groupId>org.mockito</groupId>
    <artifactId>mockito-core</artifactId>
    <version>5.2.1</version>
    <scope>test</scope>
</dependency>

<!-- H2 Database for testing (in-memory) -->
<dependency>
    <groupId>com.h2database</groupId>
    <artifactId>h2</artifactId>
    <version>2.1.214</version>
    <scope>test</scope>
</dependency>

<!-- ====================================================================
     OPTIONAL: OTHER USEFUL LIBRARIES
     ==================================================================== -->

<!-- Apache Commons Lang (for utility functions) -->
<dependency>
    <groupId>org.apache.commons</groupId>
    <artifactId>commons-lang3</artifactId>
    <version>3.12.0</version>
</dependency>

<!-- Jackson (for JSON processing if needed) -->
<dependency>
    <groupId>com.fasterxml.jackson.core</groupId>
    <artifactId>jackson-databind</artifactId>
    <version>2.15.2</version>
</dependency>

<!-- ====================================================================
     MAVEN BUILD CONFIGURATION
     Add this to your pom.xml <build> section
     ==================================================================== -->

<build>
    <plugins>
        
        <!-- Compiler Plugin (ensure Java 8+ compatibility) -->
        <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-compiler-plugin</artifactId>
            <version>3.10.1</version>
            <configuration>
                <source>1.8</source>
                <target>1.8</target>
                <encoding>UTF-8</encoding>
            </configuration>
        </plugin>
        
        <!-- JAR Plugin -->
        <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-jar-plugin</artifactId>
            <version>3.2.2</version>
        </plugin>
        
        <!-- Surefire Plugin for Tests -->
        <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-surefire-plugin</artifactId>
            <version>2.22.2</version>
            <configuration>
                <includes>
                    <include>**/*Test.java</include>
                    <include>**/*Tests.java</include>
                </includes>
            </configuration>
        </plugin>
        
    </plugins>
</build>

<!-- ====================================================================
     INSTALLATION INSTRUCTIONS
     ==================================================================== -->

<!--
STEP 1: Add dependencies to your jpos-ee/pom.xml

STEP 2: Run Maven to download dependencies
    mvn clean install

STEP 3: Verify installation
    mvn dependency:tree | grep -E "hibernate|postgresql"

STEP 4: Check for conflicts
    mvn dependency:analyze
    mvn dependency:tree -Dincludes=org.hibernate,org.postgresql

STEP 5: Build the project
    mvn clean compile

If you see build errors:
- Check Java version (needs 1.8+)
- Verify PostgreSQL driver is downloaded
- Check for duplicate dependencies
- Run: mvn dependency:resolve

-->

<!-- ====================================================================
     VERSION NOTES
     ==================================================================== -->

<!--
Hibernate 5.6.15 - Stable, widely used, good PostgreSQL support
PostgreSQL 42.7.1 - Latest stable driver
SLF4J 2.0.5 - Latest stable logging API
Logback 1.4.5 - Latest stable logging implementation
HikariCP 5.0.1 - Modern, fast connection pool

For older Java versions:
- Java 8: Use Hibernate 5.x (what we're using)
- Java 11+: Can use Hibernate 6.x or 5.6.x
- Java 17+: Use Hibernate 6.x

-->
