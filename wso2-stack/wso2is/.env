# WSO2 Identity Server Configuration

# Database
DB_TYPE=postgresql
DB_HOSTNAME=cms-postgresql
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=wso2is

# Server
HOSTNAME=cms-wso2is
PORT=9443
HTTP_PORT=8280
HTTPS_PORT=8243

# Admin Credentials (Change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Java Memory
JAVA_OPTS=-Xms256m -Xmx1024m

# SSL/TLS Configuration
KEYSTORE_PATH=/home/wso2carbon/wso2is-7.0.0/repository/resources/security/wso2carbon.jks
KEYSTORE_PASSWORD=wso2carbon
TRUSTSTORE_PATH=/home/wso2carbon/wso2is-7.0.0/repository/resources/security/client-truststore.jks
TRUSTSTORE_PASSWORD=wso2carbon

# OAuth2/OpenID Connect
OAUTH2_ENABLED=true
OIDC_ENABLED=true

# LDAP (optional)
LDAP_ENABLED=false
LDAP_URL=ldap://ldap-server:389
LDAP_DN=cn=admin,dc=example,dc=com
LDAP_PASSWORD=password

# Email Configuration (for password reset, etc.)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=password
SMTP_FROM=noreply@example.com
